name: Update Fireline hotspot data

"on":
  schedule:
    - cron: '0 */3 * * *'   # every 3 hours
  workflow_dispatch: {}      # lets you trigger it manually from the Actions tab

permissions:
  contents: write

jobs:
  update:
    runs-on: ubuntu-latest

    steps:
      - name: Check out repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: Run fetch + classify script
        env:
          FIRMS_MAP_KEY: ${{ secrets.FIRMS_MAP_KEY }}
        run: python3 fetch_and_classify.py

      - name: Commit updated data if it changed
        run: |
          git config user.name "fireline-bot"
          git config user.email "actions@users.noreply.github.com"
          git add data/
          git diff --quiet --cached || git commit -m "Update hotspot data"
          git push